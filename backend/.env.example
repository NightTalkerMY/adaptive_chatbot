# At least one Gemini API key is required.
GEMINI_API_KEY_1=your_gemini_api_key_here

# Optional additional keys used for quota-error rotation.
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=

GEMINI_MODEL_NAME=gemini-3.1-flash-lite

# Leave empty to use sqlite:///./data/chat.db.
DATABASE_URL=

# Comma-separated allowed origins, e.g. https://your-app.vercel.app
CORS_ORIGINS=*
